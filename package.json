{
  "author": "Supporterz, Inc.",
  "description": "Hocus Pocus | Knowledge Sharing Platform for GEEK-Project",
  "license": "UNLICENSED",
  "name": "hocus-pocus",
  "private": true,
  "scripts": {
    "build:ts": "tsc",
    "build:css": "tailwindcss -c ./src/features/tailwind.config.ts -i ./src/features/tailwind.index.css -o ./target/index.css",
    "build": "npm run check && npm run build:ts && npm run build:css",
    "start": "node ./target/index.js",
    "test": "vitest run src",
    "check": "biome check --write --error-on-warnings ./src",
    "audit": "npm audit --severity high"
  },
  "type": "module",
  "version": "2.1.0",
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "hono": "^4.12.30",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
